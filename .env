# App defaults (werden genutzt, wenn keine Query-Parameter in der URL gesetzt sind)
POKEAPI_GENERATION=generation-i
POKEAPI_VERSION_GROUP=red-blue
POKEAPI_LANGUAGE=de

# Logging
UVICORN_LOG_LEVEL=debug # uvicorn log level (debug, info, warning, error, critical)
APP_LOG_LEVEL=DEBUG # app log level (debug, info, warning, error, critical)

# Host-Port
POKEAPI_WEB_PORT=8000
